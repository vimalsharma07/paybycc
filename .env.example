APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Local: your dev URL (e.g. http://127.0.0.1:8000). Production: canonical HTTPS URL (no trailing slash).
APP_URL=http://localhost

# Production (https://paybycc.in) — set on the server only:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://paybycc.in
# SESSION_SECURE_COOKIE=true

# Long random string. GET /cache-clear?token=... runs `php artisan optimize:clear`.
# Leave empty locally if you do not use this route.
CACHE_CLEAR_SECRET=

# Expected settlement buffer (days) after card payment — stored on transaction records
SETTLEMENT_BUFFER_DAYS=2

# Cashfree PG API (optional; default 2023-08-01). See https://www.cashfree.com/docs/api-reference/payments/latest/orders/create
# CASHFREE_API_VERSION=2023-08-01

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# sync = no queue worker (shared hosting friendly). Ops alert mail sends in the same request.
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# SMTP (e.g. Hostinger: smtp.hostinger.com — port 465 uses implicit SSL; 587 uses STARTTLS)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.test.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Internal alerts (new user, new transaction) — sent immediately via SMTP; leave empty to disable
OPS_NOTIFICATION_EMAIL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SMS / OTP (apitxt.com). Use SMS_DRIVER=log locally to skip real SMS.
SMS_DRIVER=apitxt
SMS_AUTHKEY=
SMS_SENDER=
SMS_ROUTE=4
SMS_TEMPLATE_ID=
SMS_PE_ID=
# Must match your approved DLT template. Placeholders: {otp}, {app}
OTP_REGISTRATION_MESSAGE="Your verification code for {app} is {otp}. Valid for 10 minutes. Do not share with anyone."
# Max OTP SMS per mobile per day (all purposes). Resend cooldown: OTP_RESEND_SECONDS (default 60).
OTP_DAILY_SMS_LIMIT=10
